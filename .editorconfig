root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = unset

[*.{env,env.*}]
insert_final_newline = unset

[*.{png,jpg,jpeg,gif,ico,min.js,min.css}]
insert_final_newline = unset
trim_trailing_whitespace = unset

[package-lock.json]
insert_final_newline = unset
trim_trailing_whitespace = unset
